{
  "name": "dataflow-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:aistudio": "vite --mode aistudio",
    "backend": "cd backend && BACKEND_ENV=production python -m uvicorn main:app --reload --port 8000",
    "backend:test": "cd backend && BACKEND_ENV=test python -m uvicorn main:app --reload --port 8000",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "build:tauri": "tauri build",
    "build:docker": "npm run docker:build",
    "docker:build": "./scripts/docker_build_backend.sh",
    "docker:run": "./scripts/docker_run_backend.sh",
    "docker:compose:up": "./scripts/docker_compose_up.sh",
    "docker:compose:down": "./scripts/docker_compose_down.sh",
    "docker:compose:logs": "./scripts/docker_compose_logs.sh",
    "docker:package": "./scripts/docker_package_backend.sh",
    "package:release": "./scripts/package_release.sh",
    "preview": "vite preview",
    "tauri": "tauri",
    "check:types": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:frontend": "vitest --run",
    "test:backend": "cd backend && pytest -q",
    "test:ci": "npm run test:frontend && npm run test:backend",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^24.0.0",
    "concurrently": "^8.2.2",
    "pngjs": "^7.0.0",
    "@playwright/test": "^1.50.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0"
  }
}
